{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://openbmc.github.io/pldm/fw-update-conditions/schema.json",
    "title": "PLDM Firmware Update Conditions",
    "description": "Schema for pre/post setup targets used by platform firmware update conditions.",
    "type": "object",
    "required": ["Components"],
    "additionalProperties": false,
    "properties": {
        "Components": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/componentCondition"
            }
        }
    },
    "$defs": {
        "componentCondition": {
            "type": "object",
            "required": ["Component", "PreSetupTarget", "PostSetupTarget"],
            "additionalProperties": false,
            "properties": {
                "Component": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Component identifier used to map update conditions."
                },
                "PreSetupTarget": {
                    "type": "string",
                    "description": "Systemd target/service to run before update. Empty string means no pre-condition."
                },
                "PostSetupTarget": {
                    "type": "string",
                    "description": "Systemd target/service to run after update. Empty string means no post-condition."
                }
            }
        }
    }
}
