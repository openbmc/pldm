 class PldmEntityBase
 {
@@ -53,53 +56,20 @@ class PldmEntityBase
     PldmEntityBase& operator=(PldmEntityBase&&) noexcept = default;
     virtual ~PldmEntityBase() = default;
 
-    /** @brief Set value of partNumber in Decorator.Asset */
